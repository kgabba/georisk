# Domain where site is reachable (used for docs and future backend setup)
DOMAIN=example.com

# After Let's Encrypt (README → HTTPS): use both compose files in one command
# COMPOSE_FILE=docker-compose.yml:docker-compose.ssl.yml

# Umami Cloud — скрипт из дашборда (Collect data). Обычно:
#   https://cloud.umami.is/script.js
# Для `docker compose build` используй **GEORISK_*** ниже: пустые NEXT_PUBLIC_* в shell (Cursor и т.д.)
# перебивают подстановку из .env, из‑за этого трекер не попадал в образ.
GEORISK_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
GEORISK_UMAMI_WEBSITE_ID=
# Опционально origin сайта для NEXT_PUBLIC_API_BASE_URL в билде (по умолчанию https://$DOMAIN)
GEORISK_PUBLIC_SITE_URL=
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Optional absolute API origin for future use. Default setup: leave empty — requests use /api/ on this
# site (nginx proxies to the API). Port 3001 is internal to Compose (api service), not exposed on the host.
NEXT_PUBLIC_API_BASE_URL=

# Cadastre: browser calls GET /api/cadastre/:code → API calls https://nspd.gov.ru (browser-like headers in server.js).
# If you see TLS errors from the API container:
# ("self-signed certificate in certificate chain"), either:
# - set NSPD_TLS_INSECURE=true (disables verification only for that outbound request in code), or
# - mount your corporate/root CA and set NODE_EXTRA_CA_CERTS=/run/secrets/proxy-ca.pem
NSPD_TLS_INSECURE=
NODE_EXTRA_CA_CERTS=

# Optional HTTP(S) proxy used only for requests to nspd.gov.ru (e.g. second VPS with a clean IP).
# Example: http://login:password@203.0.113.10:3128  — lock proxy to your app server IP in firewall.
# NSPD_HTTP_PROXY is an alias for the same setting.
NSPD_HTTPS_PROXY=
NSPD_HTTP_PROXY=
# If API still returns NSPD_BLOCKED (403) from datacenter IPs, keep the proxy above; see README «НСПД».

# Google Earth Engine — рельеф участка (NASADEM), POST /api/terrain/nasadem
# Без этих переменных эндпоинт отвечает 503 GEE_NOT_CONFIGURED (Colab / браузерный OAuth не нужны).
# GOOGLE_APPLICATION_CREDENTIALS — путь к JSON сервисного аккаунта **внутри контейнера** (смонтируйте том или secret).
# GEE_PROJECT_ID — ID GCP-проекта (поле project_id в JSON сервисного аккаунта).
GEE_PROJECT_ID=
# В Docker по умолчанию compose монтирует ./secrets/google-earth-engine-sa.json → /run/secrets/gee_sa.json
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gee_sa.json

# Backend and PostGIS
POSTGRES_DB=georisk
POSTGRES_USER=georisk
POSTGRES_PASSWORD=change_me

# pgAdmin (http://127.0.0.1:5050 после compose up; с другой машины — SSH-туннель)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin

# Payment/session access control
SESSION_SECRET=change_me_long_random_secret
ACCESS_GRANT_DAYS=30
GUEST_SESSION_TTL_HOURS=10

# YooKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Optional return URL after payment, default: <site>/api/payments/yookassa/return
YOOKASSA_RETURN_URL=
# Keep enabled in production; set false only for temporary debugging
YOOKASSA_WEBHOOK_ENABLED=true
# Development-only payment mock. Keep false in production.
PAYMENT_DEV_MOCK=false
